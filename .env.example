HONCHO_API_KEY=
HONCHO_BASE_URL=https://api.honcho.dev
HONCHO_WORKSPACE_ID=openwebui
OPENWEBUI_HONCHO_IDENTITY_SALT=replace-with-at-least-32-random-characters
